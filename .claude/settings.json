    },
    "aussie-a0-bridge": {
      "path": ".claude/skills/aussie-a0-bridge/SKILL.md",
      "description": "Agent Zero v1.5+ bridge — plugin creation, A2A, memory sync, tool interop"
    }
  },
  "permissions": {
    "allow": [
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(python3.15:*)",
      "Bash(git:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd pfaa-cli && node ../.claude/hooks/typecheck.cjs",
            "timeout": 20,
            "statusMessage": "Type-checking..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/console-log-check.cjs",
            "timeout": 5,
            "statusMessage": "Checking for console.log..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/py315-check.cjs",
            "timeout": 5,
            "statusMessage": "Py3.15 check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 jmem-mcp-server/jmem/daemon.py &",
            "timeout": 3,
            "statusMessage": "Starting JMEM daemon..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/banner.cjs",
            "once": false,
            "statusMessage": "Loading Aussie Agents..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/jmem_recall.py",
            "timeout": 5,
            "statusMessage": "Recalling JMEM context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"if(process.env.ECC_HOOK_PROFILE==='off'){process.exit(0)}let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const inp=JSON.parse(d);const cmd=inp.tool_input?.command||'';const patterns=['sk-ant-','sk-proj-','ghp_','ghs_','gho_','AKIA','AIza','xoxb-','xoxp-','pat_','password=','secret=','api_key=','apikey=','token=','mongodb://','postgres://','mysql://'];const found=patterns.find(p=>cmd.toLowerCase().includes(p.toLowerCase()));if(found){process.stdout.write(JSON.stringify({decision:'block',reason:'Secret detected in command: '+found}))}})\"",
            "timeout": 5,
            "statusMessage": "Checking for secrets..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"if(process.env.ECC_HOOK_PROFILE==='off'){process.exit(0)}let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const f=(JSON.parse(d).tool_input?.file_path||'');if(f.match(/\\.(env|key|pem|p12|pfx|jks|secret)\\$/)||f.includes('credentials')||f.includes('.ssh/')||f.includes('.gnupg/')||f.includes('id_rsa')||f.includes('id_ed25519')){process.stdout.write(JSON.stringify({systemMessage:'Warning: reading sensitive file — '+f}))}})\"",
            "timeout": 5,
            "statusMessage": "Checking file sensitivity..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(node .claude/hooks/stop_scan.cjs &)",
            "statusMessage": "Scanning for new capabilities..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "(python3 .claude/hooks/jmem_store_episode.py &)",
            "timeout": 5,
            "statusMessage": "Storing JMEM episode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "(python3 .claude/hooks/cortex.py Stop &)",
            "timeout": 10,
            "statusMessage": "Cortex: stop..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"if(process.env.ECC_HOOK_PROFILE==='off'){process.exit(0)}let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const inp=JSON.parse(d);const fs=require('fs');const os=require('os');const path=require('path');const dir=path.join(os.homedir(),'.pfaa');fs.mkdirSync(dir,{recursive:true});const state={timestamp:new Date().toISOString(),trigger:inp.trigger||'unknown',conversationId:inp.conversation_id||null,tokenCount:inp.token_count||null,messageCount:inp.message_count||null};fs.writeFileSync(path.join(dir,'pre-compact-state.json'),JSON.stringify(state,null,2)+'\\n');process.stdout.write(JSON.stringify({systemMessage:'Pre-compact state saved'}))}catch(e){process.stdout.write(JSON.stringify({systemMessage:'Pre-compact save failed: '+e.message}))}})\"",
            "timeout": 10,
            "statusMessage": "Saving pre-compact state..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"if(process.env.ECC_HOOK_PROFILE==='off'){process.exit(0)}let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const inp=JSON.parse(d);const fs=require('fs');const os=require('os');const path=require('path');const dir=path.join(os.homedir(),'.pfaa');fs.mkdirSync(dir,{recursive:true});const entry={timestamp:new Date().toISOString(),trigger:inp.trigger||'unknown',summary:inp.summary||inp.compact_summary||'',conversationId:inp.conversation_id||null,tokensBeforeCompact:inp.tokens_before||null,tokensAfterCompact:inp.tokens_after||null};fs.appendFileSync(path.join(dir,'compaction-log.jsonl'),JSON.stringify(entry)+'\\n');process.stdout.write(JSON.stringify({systemMessage:'Compaction summary logged to ~/.pfaa/compaction-log.jsonl'}))}catch(e){process.stdout.write(JSON.stringify({systemMessage:'Compaction log failed: '+e.message}))}})\"",
            "timeout": 10,
            "statusMessage": "Logging compaction summary..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py SubagentStart",
            "timeout": 5,
            "statusMessage": "Cortex: agent start..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py SubagentStop",
            "timeout": 10,
            "statusMessage": "Cortex: agent stop..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py PostToolUseFailure",
            "timeout": 5,
            "statusMessage": "Cortex: tool failure..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py TaskCompleted",
            "timeout": 5,
            "statusMessage": "Cortex: task done..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py UserPromptSubmit",
            "timeout": 3,
            "statusMessage": "Cortex: recall..."
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "*.py|*.pyi|settings.json|.claude/agents/*.md",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cortex.py FileChanged",
            "timeout": 10,
            "statusMessage": "Cortex: file scan..."
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const inp=JSON.parse(d);const tool=inp.tool_name||'';const retryable=['Bash','Read','Glob','Grep'];if(retryable.includes(tool)){process.stdout.write(JSON.stringify({retry:true}))}else{process.stdout.write(JSON.stringify({retry:false}))}}catch{process.stdout.write(JSON.stringify({retry:false}))}})\"",
            "timeout": 5,
            "statusMessage": "Evaluating permission denial..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/statusline.cjs",
    "padding": 0
  },
  "enableAllProjectMcpServers": true,
  "mcpServers": {
    "jmem": {
      "command": "python3",
      "args": [
        "-m",
        "jmem"
      ],
      "cwd": ".",
      "env": {
        "PYTHONPATH": "python",
        "PFAA_AGENT_NAME": "claude-code"
      }
    }
  }
}
