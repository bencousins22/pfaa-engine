    },
    "aussie-audit": {
      "path": ".claude/skills/aussie-audit/SKILL.md",
      "description": "Self-assessment and reliability audit"
    },
    "aussie-learn": {
      "path": ".claude/skills/aussie-learn/SKILL.md",
      "description": "Full JMEM cognitive cycle — recall, reward, consolidate, meta-learn, emergent, extract, decay, status"
    },
    "aussie-status": {
      "path": ".claude/skills/aussie-status/SKILL.md",
