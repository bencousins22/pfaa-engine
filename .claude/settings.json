    },
    "aussie-swarm": {
      "path": ".claude/skills/aussie-swarm/SKILL.md",
      "description": "Multi-agent swarm — 8 specialists in parallel"
    },
    "aussie-chat": {
      "path": ".claude/skills/aussie-chat/SKILL.md",
      "description": "Interactive Aussie Agents chat loop"
    },
    "aussie-exec": {
      "path": ".claude/skills/aussie-exec/SKILL.md",
      "description": "Python sandbox, tool execution, scatter, pipeline"
    },
    "aussie-analyze": {
      "path": ".claude/skills/aussie-analyze/SKILL.md",
      "description": "Python 3.15 code analysis (PEP 810/814/695)"
    },
    "aussie-memory": {
      "path": ".claude/skills/aussie-memory/SKILL.md",
      "description": "JMEM memory — stats, recall, learn, consolidate"
    },
    "aussie-build": {
      "path": ".claude/skills/aussie-build/SKILL.md",
      "description": "Self-improvement cycle, explore, generate"
    },
    "aussie-tools": {
      "path": ".claude/skills/aussie-tools/SKILL.md",
      "description": "List tools, search tools, status, benchmarks"
    },
    "aussie-warmup": {
      "path": ".claude/skills/aussie-warmup/SKILL.md",
