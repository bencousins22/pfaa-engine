# PFAA FreqTrade — Environment Variables
# Copy to .env and fill in your values

# Binance API (required for live/dry-run trading)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# FreqTrade API (for FreqUI connection)
FREQTRADE_API_USER=pfaa
FREQTRADE_API_PASS=change_me_in_production
FREQTRADE_JWT_SECRET=generate_a_random_secret_here

# Telegram notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Ports (Railway auto-assigns, local docker uses these)
FREQTRADE_PORT=8080
FREQUI_PORT=8081
