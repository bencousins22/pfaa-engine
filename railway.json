{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
    },
    "deploy": {
        "startCommand": "freqtrade trade --config /freqtrade/config.json --strategy PFAABitcoinStrategy --strategy-path /freqtrade/user_data/strategies",
        "healthcheckPath": "/api/v1/ping",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}
