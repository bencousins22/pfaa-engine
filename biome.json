{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "warn"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "files": {
    "include": ["src/**/*.ts", "pfaa-cli/src/**/*.ts"],
    "ignore": ["node_modules", "dist", ".claude"]
  }
}
