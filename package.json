{
  "name": "@aussie-agents/pfaa",
  "version": "0.1.0",
  "description": "Platform for Autonomous Agents — enterprise CLI with phase-fluid execution, 9-tier agent swarm, Python 3.15 sandbox, and dual-provider AI (Claude + Gemini)",
  "type": "module",
  "bin": {
    "pfaa": "./bin/pfaa.js",
    "pfaa-cli": "./bin/pfaa-cli.js"
  },
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "files": [
    "bin/",
    "dist/",
    "python/",
    "pfaa.config.json",
    "mcp.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --watch bin/pfaa-cli.js",
    "start": "node bin/pfaa-cli.js",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit && pytest tests/ -v",
    "prepublishOnly": "npm run build",
    "postinstall": "node bin/postinstall.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "p-queue": "^8.1.0",
    "strip-ansi": "^7.1.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "ai",
    "agents",
    "cli",
    "claude",
    "gemini",
    "autonomous",
    "pfaa",
    "mcp",
    "enterprise",
    "swarm",
    "memory",
    "q-learning"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bencousins22/pfaa-engine"
  },
  "license": "MIT",
  "author": "Aussie Agents <team@aussieagents.dev>"
}
